{
  "name": "fabric-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/src/server.js",
    "start": "npm run build && node dist/src/server.js",
    "lint": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node dist/scripts/bootstrap-db.js && node --test tests/**/*.test.mjs",
    "db:bootstrap": "npm run build && node dist/scripts/bootstrap-db.js",
    "validate:env": "powershell -ExecutionPolicy Bypass -File scripts/validate-env.ps1",
    "retention:search-logs": "npm run build && node dist/scripts/retention-search-logs.js",
    "mcp:stdio": "npm run build && node dist/scripts/mcp-stdio-server.js",
    "smoke:mcp": "powershell -ExecutionPolicy Bypass -File scripts/smoke-mcp.ps1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
